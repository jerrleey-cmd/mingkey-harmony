{
  "app": {
    "compileMode": "moduleStrategy",
    "products": [
      {
        "name": "default",
        "signingConfig": "debug"
      }
    ],
    "buildOption": {
      "sourceOption": {
        "workers": []
      }
    }
  },
  "modules": [
    {
      "name": "keyboard",
      "srcPath": "./keyboard",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
